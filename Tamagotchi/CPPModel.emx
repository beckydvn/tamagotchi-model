              <language>C++</language>
              <body>snackCount = 0;</body>
            </effect>
            <trigger xmi:id="_58nUoDYAEfGJaL0kWrhu3A" name="" event="_qC8GMDYAEfGJaL0kWrhu3A" port="_wczNgDVLEfGJaL0kWrhu3A"/>
