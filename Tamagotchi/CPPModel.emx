          <subvertex xmi:type="uml:Pseudostate" xmi:id="_GuD-IDYSEfGJaL0kWrhu3A" kind="choice"/>
          <transition xmi:id="_6GHbpDYQEfGJaL0kWrhu3A" name="Initial" source="_6GHbojYQEfGJaL0kWrhu3A" target="_6GHbozYQEfGJaL0kWrhu3A">
