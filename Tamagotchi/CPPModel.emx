            </trigger>
          </transition>
          <transition xmi:id="_GVnfQDUdEfGJaL0kWrhu3A" name="50% chance" source="_0CqsUDUcEfGJaL0kWrhu3A" target="_3UCvwDUXEfGJaL0kWrhu3A" guard="_QnuoQDUdEfGJaL0kWrhu3A">
            <ownedRule xmi:id="_QnuoQDUdEfGJaL0kWrhu3A">
              <specification xmi:type="uml:OpaqueExpression" xmi:id="_QnuoQTUdEfGJaL0kWrhu3A" name="Guard">
                <language>C++</language>
                <body>return (rng &lt;= 50);</body>
              </specification>
            </ownedRule>
          </transition>
          <transition xmi:id="_Orl2QDUeEfGJaL0kWrhu3A" name="30% chance" source="_0CqsUDUcEfGJaL0kWrhu3A" target="_X3sO4DUdEfGJaL0kWrhu3A" guard="_UKgWADUeEfGJaL0kWrhu3A">
            <ownedRule xmi:id="_UKgWADUeEfGJaL0kWrhu3A">
              <specification xmi:type="uml:OpaqueExpression" xmi:id="_UKgWATUeEfGJaL0kWrhu3A" name="Guard">
                <language>C++</language>
                <body>return (rng > 50 &amp;&amp; rng &lt;= 80);</body>
              </specification>
            </ownedRule>
          </transition>
          <transition xmi:id="_wTh2MDUeEfGJaL0kWrhu3A" name="20% chance" source="_0CqsUDUcEfGJaL0kWrhu3A" target="_W4b74DUeEfGJaL0kWrhu3A" guard="_y1jHADUeEfGJaL0kWrhu3A">
            <ownedRule xmi:id="_y1jHADUeEfGJaL0kWrhu3A">
              <specification xmi:type="uml:OpaqueExpression" xmi:id="_y1jHATUeEfGJaL0kWrhu3A" name="Guard">
                <language>C++</language>
                <body>return (rng > 80 &amp;&amp; rng &lt;= 100);</body>
              </specification>
            </ownedRule>
          </transition>
