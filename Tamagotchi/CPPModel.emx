      <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_-IkOQDRsEfGs993j7RVgLQ" name="showStatus" specification="_mW9aQDRsEfGs993j7RVgLQ">
        <language>C++</language>
        <body>std::cout&lt;&lt; &quot;\n-----------------------------------------------------------------------&quot; &lt;&lt;std::endl;&#xD;
std::cout&lt;&lt; tama_name &lt;&lt; &quot; STATUS:\n&quot; &lt;&lt; &quot;\nHUNGER: &quot; &lt;&lt; hunger &lt;&lt; &quot;\nHAPPINESS: &quot; &lt;&lt; happiness &lt;&lt; &quot;\nDISCIPLINE: &quot; &lt;&lt; discipline &lt;&lt; &quot;\nHEALTH: &quot; &lt;&lt; health &lt;&lt;std::endl;&#xD;
std::cout&lt;&lt; &quot;-----------------------------------------------------------------------&quot; &lt;&lt;std::endl;</body>
      </ownedBehavior>
