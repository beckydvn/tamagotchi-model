          <transition xmi:id="_JWO6QDYSEfGJaL0kWrhu3A" name="throwBall" source="_F-PgMDYREfGJaL0kWrhu3A" target="_GuD-IDYSEfGJaL0kWrhu3A">
            <effect xmi:type="uml:OpaqueBehavior" xmi:id="_UrMnYDYSEfGJaL0kWrhu3A" name="Effect">
              <language>C++</language>
              <body>std::cout &lt;&lt; &quot;THREW THE BALL!&quot; &lt;&lt; std::endl;&#xD;
throwCount += 1;</body>
            </effect>
            <trigger xmi:id="_NAlFEDYSEfGJaL0kWrhu3A" name="" event="_H8YycDYSEfGJaL0kWrhu3A" port="_8uRwsDYQEfGJaL0kWrhu3A"/>
          </transition>
          <transition xmi:id="_cxziIDYSEfGJaL0kWrhu3A" name="throws &lt;= 5" source="_GuD-IDYSEfGJaL0kWrhu3A" target="_F-PgMDYREfGJaL0kWrhu3A" guard="_jydhcDYSEfGJaL0kWrhu3A">
            <ownedRule xmi:id="_jydhcDYSEfGJaL0kWrhu3A">
              <specification xmi:type="uml:OpaqueExpression" xmi:id="_jydhcTYSEfGJaL0kWrhu3A" name="Guard">
                <language>C++</language>
                <body>return (throwCount &lt;= 5);</body>
              </specification>
            </ownedRule>
            <effect xmi:type="uml:OpaqueBehavior" xmi:id="_8kw9cDYSEfGJaL0kWrhu3A" name="Effect">
              <language>C++</language>
              <body>std::cout &lt;&lt; &quot;PET CAUGHT THE BALL!&quot; &lt;&lt; std::endl;&#xD;
updateValPort.updateHappiness(2).send();</body>
            </effect>
          </transition>
          <transition xmi:id="_BzMKIDYTEfGJaL0kWrhu3A" name="caught last" source="_GuD-IDYSEfGJaL0kWrhu3A" target="_F-PgMDYREfGJaL0kWrhu3A">
