          <transition xmi:id="_FT1t0DVMEfGJaL0kWrhu3A" name="feed activated" source="_454TEDVBEfGJaL0kWrhu3A" target="_IqQbkDVCEfGJaL0kWrhu3A">
            <trigger xmi:id="_IQBLEDVMEfGJaL0kWrhu3A" name="" event="_NZcSEDVDEfGJaL0kWrhu3A" port="_wczNgDVLEfGJaL0kWrhu3A"/>
          </transition>
          <transition xmi:id="_cp09kDXgEfGJaL0kWrhu3A" name="getSnack" source="_IqQbkDVCEfGJaL0kWrhu3A" target="_vW5i4DXvEfGJaL0kWrhu3A">
            <effect xmi:type="uml:OpaqueBehavior" xmi:id="_UGBWMDXwEfGJaL0kWrhu3A" name="Effect">
              <language>C++</language>
              <body>std::cout&lt;&lt; &quot;\nATE THE SNACK...&quot; &lt;&lt;std::endl;&#xD;
snackCount += 1;</body>
            </effect>
            <trigger xmi:id="_euye8DXgEfGJaL0kWrhu3A" name="" event="_EnhbIDXgEfGJaL0kWrhu3A" port="_wczNgDVLEfGJaL0kWrhu3A"/>
          </transition>
          <transition xmi:id="_2p7roDXvEfGJaL0kWrhu3A" name="snackCount &lt; 3" source="_vW5i4DXvEfGJaL0kWrhu3A" target="_IqQbkDVCEfGJaL0kWrhu3A" guard="_6LJIkDXvEfGJaL0kWrhu3A">
            <ownedRule xmi:id="_6LJIkDXvEfGJaL0kWrhu3A">
              <specification xmi:type="uml:OpaqueExpression" xmi:id="_6LJvoDXvEfGJaL0kWrhu3A" name="Guard">
                <language>C++</language>
                <body>return (snackCount &lt; 3);</body>
              </specification>
            </ownedRule>
            <effect xmi:type="uml:OpaqueBehavior" xmi:id="_AJn4MDX7EfGJaL0kWrhu3A" name="Effect">
              <language>C++</language>
              <body>updateValPort.updateHunger(-2).send();</body>
            </effect>
          </transition>
          <transition xmi:id="_-vTQQDXvEfGJaL0kWrhu3A" name="else" source="_vW5i4DXvEfGJaL0kWrhu3A" target="_IqQbkDVCEfGJaL0kWrhu3A" guard="_B6KpwDXwEfGJaL0kWrhu3A">
            <ownedRule xmi:id="_B6KpwDXwEfGJaL0kWrhu3A">
              <specification xmi:type="uml:OpaqueExpression" xmi:id="_B6LQ0DXwEfGJaL0kWrhu3A" name="Guard">
                <language>C++</language>
                <body>return (snackCount >= 3);</body>
              </specification>
            </ownedRule>
            <effect xmi:type="uml:OpaqueBehavior" xmi:id="_EMqP0DX7EfGJaL0kWrhu3A" name="Effect">
              <language>C++</language>
              <body>std::cout&lt;&lt; &quot;\nSO...MANY...SNACKS...&quot; &lt;&lt;std::endl;&#xD;
updateValPort.updateHunger(-1).send();&#xD;
updateValPort.updateHealth(-3).send();</body>
            </effect>
          </transition>
          <transition xmi:id="_rBzpkDX9EfGJaL0kWrhu3A" name="getMeal" source="_IqQbkDVCEfGJaL0kWrhu3A" target="_IqQbkDVCEfGJaL0kWrhu3A">
            <effect xmi:type="uml:OpaqueBehavior" xmi:id="_wAme0DX9EfGJaL0kWrhu3A" name="Effect">
              <language>C++</language>
              <body>std::cout&lt;&lt; &quot;\nYOU FED YOUR PET A MEAL.&quot; &lt;&lt;std::endl;&#xD;
updateValPort.updateHunger(3).send();</body>
            </effect>
            <trigger xmi:id="_thTx4DX9EfGJaL0kWrhu3A" name="" event="_lw37cDX9EfGJaL0kWrhu3A" port="_wczNgDVLEfGJaL0kWrhu3A"/>
          </transition>
          <transition xmi:id="_3BGlwDYAEfGJaL0kWrhu3A" name="exit" source="_IqQbkDVCEfGJaL0kWrhu3A" target="_454TEDVBEfGJaL0kWrhu3A">
