          <subvertex xmi:type="uml:State" xmi:id="_Ot6wgDUpEfGJaL0kWrhu3A" name="Take Input">
            <entry xmi:type="uml:OpaqueBehavior" xmi:id="_Z0mKADUpEfGJaL0kWrhu3A" name="Entry">
              <language>C++</language>
              <body>char userInput[256];&#xD;
&#xD;
while(true){&#xD;
	fgets(userInput, sizeof(userInput), stdin);&#xD;
&#xD;
	userInput[strcspn(userInput, &quot;\n&quot;)] = '\0';&#xD;
&#xD;
	for (int i = 0; userInput[i]; i++) {&#xD;
			userInput[i] = toupper(userInput[i]);&#xD;
	}&#xD;
&#xD;
	inputPort.gotInput(userInput).send();&#xD;
}</body>
            </entry>
          </subvertex>
          <transition xmi:id="_90NBYjUoEfGJaL0kWrhu3A" name="Initial" source="_90NBYDUoEfGJaL0kWrhu3A" target="_90NBYTUoEfGJaL0kWrhu3A">
