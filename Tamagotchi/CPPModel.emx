            <ownedRule xmi:id="_QnuoQDUdEfGJaL0kWrhu3A">
              <specification xmi:type="uml:OpaqueExpression" xmi:id="_QnuoQTUdEfGJaL0kWrhu3A" name="Guard">
                <language>C++</language>
                <body>return (rng &lt;= 50);</body>
              </specification>
            </ownedRule>
            <effect xmi:type="uml:OpaqueBehavior" xmi:id="_nHuvwDX0EfGJaL0kWrhu3A" name="Effect">
              <language>C++</language>
              <body>std::cout&lt;&lt; &quot;\n&quot; &lt;&lt; tama_name &lt;&lt; &quot; IS GETTING HUNGRY...&quot; &lt;&lt;std::endl;&#xD;
hunger += 1;</body>
            </effect>
