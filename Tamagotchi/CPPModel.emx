            <effect xmi:type="uml:OpaqueBehavior" xmi:id="_8hdGYDX0EfGJaL0kWrhu3A" name="Effect">
              <language>C++</language>
              <body>std::cout&lt;&lt; &quot;\n&quot; &lt;&lt; tama_name &lt;&lt; &quot; IS GETTING ROWDY...&quot; &lt;&lt;std::endl;&#xD;
discipline -= 1;</body>
