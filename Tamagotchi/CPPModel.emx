              <specification xmi:type="uml:OpaqueExpression" xmi:id="_UKgWATUeEfGJaL0kWrhu3A" name="Guard">
                <language>C++</language>
                <body>return (rng > 50 &amp;&amp; rng &lt;= 80);</body>
              </specification>
            </ownedRule>
            <effect xmi:type="uml:OpaqueBehavior" xmi:id="_rfzjQDX0EfGJaL0kWrhu3A" name="Effect">
              <language>C++</language>
              <body>std::cout&lt;&lt; &quot;\n&quot; &lt;&lt; tama_name &lt;&lt; &quot; IS GETTING BORED...&quot; &lt;&lt;std::endl;&#xD;
happiness -= 1;</body>
            </effect>
          </transition>
          <transition xmi:id="_wTh2MDUeEfGJaL0kWrhu3A" name="20% chance" source="_0CqsUDUcEfGJaL0kWrhu3A" target="_Vr7RADUUEfGPsvtei6AytQ" guard="_y1jHADUeEfGJaL0kWrhu3A">
