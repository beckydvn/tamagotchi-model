          <subvertex xmi:type="uml:State" xmi:id="_Ot6wgDUpEfGJaL0kWrhu3A" name="Take Input">
            <entry xmi:type="uml:OpaqueBehavior" xmi:id="_Z0mKADUpEfGJaL0kWrhu3A" name="Entry">
              <language>C++</language>
              <body>char user_input[256];&#xD;
&#xD;
fgets(user_input, sizeof(user_input), stdin);&#xD;
&#xD;
// Remove trailing newline if present&#xD;
input[strcspn(user_input, &quot;\n&quot;)] = '\0';&#xD;
&#xD;
for (int i = 0; user_input[i]; i++) {&#xD;
        user_input[i] = toupper(user_input[i]);&#xD;
}&#xD;
&#xD;
input = user_input;&#xD;
&#xD;
std::cout&lt;&lt; &quot;\nGOT INPUT &quot; &lt;&lt; input &lt;&lt;std::endl;</body>
            </entry>
          </subvertex>
