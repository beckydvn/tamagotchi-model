          <transition xmi:id="_Orl2QDUeEfGJaL0kWrhu3A" name="dec happiness (30% chance)" source="_0CqsUDUcEfGJaL0kWrhu3A" target="_Vr7RADUUEfGPsvtei6AytQ" guard="_UKgWADUeEfGJaL0kWrhu3A">
