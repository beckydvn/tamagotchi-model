            <entry xmi:type="uml:OpaqueBehavior" xmi:id="_Z0mKADUpEfGJaL0kWrhu3A" name="Entry">
              <language>C++</language>
              <body>char userInput[256];&#xD;
fgets(userInput, sizeof(userInput), stdin);&#xD;
&#xD;
userInput[strcspn(userInput, &quot;\n&quot;)] = '\0';&#xD;
&#xD;
for (int i = 0; userInput[i]; i++) {&#xD;
		userInput[i] = toupper(userInput[i]);&#xD;
}&#xD;
&#xD;
inputPort.gotInput(userInput).send();</body>
            </entry>
          </subvertex>
